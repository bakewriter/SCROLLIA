// 装備中シリーズ効果を計算
function getSeriesBonus() {
  const count = {};
  for (const slot of ['head','body','ring']) {
    const item = S.equipped && S.equipped[slot];
    if (!item || !item.seriesKey) continue;
    count[item.seriesKey] = (count[item.seriesKey] || 0) + 1;
  }
  const bonuses = {};
  for (const [series, cnt] of Object.entries(count)) {
    if (cnt >= 2) {
      const ef = SERIES_EFFECTS[series];
      if (ef) bonuses[ef.effect] = (bonuses[ef.effect] || 0) + ef.value * (cnt >= 3 ? 2 : 1);
    }
  }
  return bonuses;
}

