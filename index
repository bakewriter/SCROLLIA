  const base = EQUIPMENT_BASE[baseKey];
  if (!base) return null;
  const v = EQUIP_RARITY_VARIANCE[base.rarity];
  const roll = (val) => val === 0 ? 0 : Math.max(1, Math.round(val * (1 + (Math.random() * 2 - 1) * v)));
  const rollMult = (val) => val === 0 ? 0 : Math.round((val + (Math.random() * 2 - 1) * v * 0.5) * 100) / 100;
  return {
    baseKey,
    hp:   roll(base.baseHp),
    luk:  roll(base.baseLuk),
    mult: rollMult(base.baseMult),
  };
}

