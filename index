// 個人ページから購入
async function buyFromUserProfile(uid, idx) {
  if (!window._fbUser || !window._fb) return;
  try {
    const { db, doc, getDoc, updateDoc } = window._fb;
    const snap = await getDoc(doc(db, 'users', uid));
    if (!snap.exists()) return;
    const p = snap.data();
    const listings = p.bazaarListings || [];
    const item = listings[idx];
    if (!item || S.gold < item.price) return;
    S.gold -= item.price;
    if (item.grimoireRarity) {
      if (!S.grimoires) S.grimoires = [];
      S.grimoires.push({ rarity: item.grimoireRarity });
    } else {
      addScroll(item.scrollType, 1);
    }
    // 相手の出品リストから削除
    listings.splice(idx, 1);
    await updateDoc(doc(db, 'users', uid), { bazaarListings: listings });
    saveGame();
    alert('購入しました！');
    openUserProfile(uid);
  } catch(e) { dbg('BUY ERROR: ' + e.message); }
}

