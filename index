const _debugLog = [];
function dbg(msg, type) {
  const time = new Date().toLocaleTimeString('ja-JP', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const cls = type || (msg.startsWith('ERROR') ? 'error' : msg.startsWith('WARN') ? 'warn' : msg.startsWith('switchTab') ? 'info' : '');
  _debugLog.push({ time, msg, cls });
  if (_debugLog.length > 60) _debugLog.shift();
  const el = document.getElementById('debug-panel-body');
  if (el) {
    const div = document.createElement('div');
    if (cls) div.className = cls;
    div.textContent = `[${time}] ${msg}`;
    el.insertBefore(div, el.firstChild);
    if (el.children.length > 60) el.removeChild(el.lastChild);
  }
}

