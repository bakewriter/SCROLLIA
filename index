// ==================== WORLD CHAT ====================
// Phase B: WorldChat.send / WorldChat.subscribe を Firestore版に差し替える
// msg schema: { uid, name, text, ts }
// Firestore: collection('world_chat'), orderBy('ts'), limitToLast(100)

const WC_NPC_NAMES = ['ミラル','老魔法使い','旅人ヒース','盗賊のカイン','聖騎士ユーナ','風の民アーシャ','ギルド員ボルド','謎の術者'];
const WC_NPC_MSGS = [
  'SPダンジョン今日もクリアした！',
  '竜の聖域、誰か一緒に行かない？',
  'バザーに安い炎魔法出してるよ〜',
  'Lv10超えたら面白くなってくるよな',
  '結晶ゴーレム強すぎ…',
  '混沌魔法って運ゲーすぎｗ',
  'SPが高いと火炎魔法えぐいダメージ出るよ',
  '聖魔法アンデッドに2倍入るの知ってた？',
  'ゴールド稼ぎは洞窟が安定',
  'バザーで豊穣の指輪買えた！',
  '毎日SP+1地道に続けてます',
  '大魔導士ローブ高すぎ…でも欲しい',
];

// ---- ローカル実装（Phase Bで差し替え） ----
const WorldChat = {
  _key: 'scrollia_world_chat',
  _max: 100,
  _listeners: [],

  _load() {
    try { return JSON.parse(localStorage.getItem(this._key) || '[]'); } catch { return []; }
  },
  _save(msgs) {
    localStorage.setItem(this._key, JSON.stringify(msgs.slice(-this._max)));
  },
  // Phase B: db.collection('world_chat').add({ uid, name, text, ts: serverTimestamp() })
  async send(msg) {
    const msgs = this._load();
    msgs.push(msg);
    // 40%でNPC返答
    if (Math.random() < 0.4) {
      const replyPool = ['お、いいね！','わかるわ〜','がんばれ！','それ俺も思ってた','一緒に冒険しようぜ','SP高い人は強いよな','ドロップ率LUKで上がるよ'];
      msgs.push({
        uid: 'npc',
        name: WC_NPC_NAMES[Math.floor(Math.random() * WC_NPC_NAMES.length)],
        text: replyPool[Math.floor(Math.random() * replyPool.length)],
        ts: Date.now() + 500,
      });
    }
    this._save(msgs);
    this._notify(msgs);
  },
  // Phase B: db.collection('world_chat').orderBy('ts').limitToLast(100).onSnapshot(cb)
  subscribe(cb) {
    this._listeners.push(cb);
    cb(this._load());
    return () => { this._listeners = this._listeners.filter(l => l !== cb); };
  },
  _notify(msgs) {
    this._listeners.forEach(cb => cb(msgs));
  },
};

// seed
(function() {
  if (WorldChat._load().length === 0) {
    const msgs = [];
    for (let i = 0; i < 6; i++) {
      msgs.push({
        uid: 'npc',
        name: WC_NPC_NAMES[Math.floor(Math.random() * WC_NPC_NAMES.length)],
        text: WC_NPC_MSGS[Math.floor(Math.random() * WC_NPC_MSGS.length)],
        ts: Date.now() - (6 - i) * 180000,
      });
    }
    WorldChat._save(msgs);
  }
})();

let _wcUnsub = null;

function initWcWindow() {
  if (_wcUnsub) _wcUnsub();
  _wcUnsub = WorldChat.subscribe(msgs => {
    const win = document.getElementById('wc-window');
    if (!win) return;
    win.innerHTML = msgs.map(m => {
      const isMe = m.uid === 'player_local';
      const time = new Date(m.ts).toLocaleTimeString('ja-JP', {hour:'2-digit', minute:'2-digit'});
      return `
        <div class="chat-msg" style="${isMe ? 'text-align:right' : ''}">
          <div class="cm-name ${isMe ? 'player' : 'npc'}">${escHtml(m.name)} <span style="color:var(--text3);font-size:10px;font-weight:normal">${time}</span></div>
          <div class="cm-text" style="${isMe ? 'background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.2);' : ''}display:inline-block;max-width:85%">${escHtml(m.text)}</div>
        </div>`;
    }).join('');
    win.scrollTop = win.scrollHeight;
  });
}

