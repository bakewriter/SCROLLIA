function loadGame() {
  const d = localStorage.getItem('scroll_chronicle_save');
  if (d) {
    try {
      const parsed = JSON.parse(d);
      S = Object.assign(DEFAULT_STATE(), parsed);
      // 旧scrollsデータをscrollItemsに変換
      if (S.scrolls && !parsed.scrollItems) {
        S.scrollItems = [];
        for (const [k, v] of Object.entries(S.scrolls)) {
          if (SCROLLS[k]) {
            for (let i = 0; i < v; i++) S.scrollItems.push({ key: k, lv: 1 });
          }
        }
      }
      if (!S.scrollItems) S.scrollItems = [];
      if (!S.equipped) S.equipped = { head:null, body:null, ring:null, grimoire:null };
      if (S.equipped.grimoire === undefined) S.equipped.grimoire = null;
      if (!S.bossBadges) S.bossBadges = {};
      if (!S.stageBadges) S.stageBadges = {};
      if (!S.encounteredMonsters) S.encounteredMonsters = {};
      if (!S.inventory) S.inventory = [];
      if (!S.grimoires) S.grimoires = [];
      if (!S.pets) S.pets = [];
      if (!S.activePets) S.activePets = [];
      if (!S.contractBloods) S.contractBloods = {};
      if (!S.bazaarListings) S.bazaarListings = [];
      delete S.scrolls;
      delete S.equip;
    } catch(e) {
      console.error('loadGame error:', e);
      S = DEFAULT_STATE();
    }
  }
}

