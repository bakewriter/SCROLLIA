  const roll = (val) => val === 0 ? 0 : Math.max(1, Math.round(val * (1 + (Math.random() * 2 - 1) * v)));
  const rollMult = (val) => val === 0 ? 0 : Math.round((val + (Math.random() * 2 - 1) * v * 0.3) * 100) / 100;
  return {
    baseKey: seriesKey,
    seriesKey: base.series,
    hp:   roll(base.baseHp),
    luk:  roll(base.baseLuk),
    mult: rollMult(base.baseMult),
    isSeries: true,
  };
}


