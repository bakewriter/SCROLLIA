// プロフィール保存
async function fbSaveProfile() {
  if (!window._fbUser || !window._fb) return;
  try {
    const { db, doc, setDoc } = window._fb;
    // 最高到達ダンジョンを計算
    let maxArea = '未到達', maxStage = 0;
    const areaOrder = ['forest','cave','ruins','dragon_lair'];
    for (const akey of [...areaOrder].reverse()) {
      if (S.bossBadges && S.bossBadges[akey]) { maxArea = AREAS[akey].name + ' BOSS'; maxStage = 99; break; }
      for (let s = 5; s >= 1; s--) {
        if (S.stageBadges && S.stageBadges[`${akey}_s${s}`]) {
          maxArea = AREAS[akey].name; maxStage = s; break;
        }
      }
      if (maxStage > 0) break;
    }
    await setDoc(doc(db, 'users', window._fbUser.uid), {
      displayName: window._fbUser.displayName,
      photoURL: window._fbUser.photoURL || '',
      maxArea,
      maxStage,
      equipped: S.equipped || {},
      bazaarListings: S.bazaarListings || [],
      updatedAt: Date.now(),
    }, { merge: true });
  } catch(e) { dbg('PROFILE SAVE ERROR: ' + e.message); }
}

