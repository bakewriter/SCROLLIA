function postBazaar() {
  const sel = document.getElementById('baz-item-sel').value;
  const price = parseInt(document.getElementById('baz-price').value) || 1;

  if (!sel || sel === '') { alert('出品するアイテムを選択してください'); return; }

  if (sel.startsWith('grimoire:')) {
    const gIdx = parseInt(sel.split(':')[1]);
    if (!S.grimoires[gIdx]) return;
    const g = S.grimoires.splice(gIdx, 1)[0];
    S.bazaarListings.push({ seller:'あなた', icon:'🧙‍♂️', grimoireRarity: g.rarity, qty:1, price });
  } else {
    const type = sel.replace('scroll:', '');
    const qty = parseInt(document.getElementById('baz-qty').value) || 1;
    if (!type || countScrolls(type) < qty) { alert('スクロールが足りません'); return; }
    const fair = SCROLL_FAIR_PRICE[type] || 50;
    const probPct = Math.round(Math.min(0.99, 0.5 * Math.exp(-(price/fair - 1))) * 100);
    removeScrollByKey(type, qty);
    S.bazaarListings.push({ seller:'あなた', icon:'🧙‍♂️', scrollType: type, qty, price });
    const simEl = document.getElementById('baz-sim-result');
    if (simEl) simEl.textContent = `出品完了。売れる確率: 約${probPct}%（相場: ${fair}G）`;
  }
  render();
}

function buyFromBazaar(idx) {
  const all = [...BAZAAR_NPC_SEED, ...S.bazaarListings];
  const item = all[idx];
  if (!item || S.gold < item.price) return;
  S.gold -= item.price;
  if (item.grimoireRarity) {
    if (!S.grimoires) S.grimoires = [];
    S.grimoires.push({ rarity: item.grimoireRarity });
  } else {
    addScroll(item.scrollType, 1);
  }
  const isNpc = !item.seller || item.seller !== 'あなた';
  if (!isNpc) {
    const listIdx = idx - BAZAAR_NPC_SEED.length;
    if (listIdx >= 0) {
      S.bazaarListings[listIdx].qty--;
      if (S.bazaarListings[listIdx].qty <= 0) S.bazaarListings.splice(listIdx, 1);
    }
  }
  render();
}

function cancelListing(listIdx) {
  const item = S.bazaarListings[listIdx];
  if (!item) return;
  if (item.grimoireRarity) {
    if (!S.grimoires) S.grimoires = [];
    S.grimoires.push({ rarity: item.grimoireRarity });
  } else {
    for (let i = 0; i < item.qty; i++) addScroll(item.scrollType, 1);
  }
  S.bazaarListings.splice(listIdx, 1);
  render();
}

// ==================== 行商人 ====================

function getMerchantSeed() {
  // 12時間ごとにシード変更（UTC基準）
  return Math.floor(Date.now() / (1000 * 60 * 60 * 12));
}

function seededRandom(seed) {
  let x = Math.sin(seed) * 10000;
  return x - Math.floor(x);
}

function getMerchantStock() {
  const seed = getMerchantSeed();
  const allKeys = Object.keys(SCROLLS).filter(k => SCROLLS[k].rarity !== 'architect');
  const stock = [];
  const used = new Set();
  for (let i = 0; stock.length < 6; i++) {
    const idx = Math.floor(seededRandom(seed + i * 7919) * allKeys.length);
    const key = allKeys[idx];
    if (!used.has(key)) {
      used.add(key);
      const sc = SCROLLS[key];
      const basePrice = SCROLL_SHOP_PRICE[sc.rarity];
      // 行商人価格：定価の0.7〜1.3倍のランダム
      const multi = 0.7 + seededRandom(seed + i * 1009) * 0.6;
      const price = Math.max(1, Math.floor(basePrice * multi));
      const qty = 1 + Math.floor(seededRandom(seed + i * 3571) * 4);
      stock.push({ key, price, qty });
    }
  }
  return stock;
}

function getMerchantNextReset() {
  const next = (getMerchantSeed() + 1) * 1000 * 60 * 60 * 12;
  const diff = next - Date.now();
  const h = Math.floor(diff / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  return `${h}時間${m}分後`;
}

function renderChat() {
  const stock = getMerchantStock();
  let itemHtml = stock.map((item, i) => {
    const sc = SCROLLS[item.key];
    const color = RARITY[sc.rarity].color;
    const fairPrice = SCROLL_SHOP_PRICE[sc.rarity];
    const isDiscount = item.price < fairPrice;
    const priceLabel = isDiscount
      ? `<span style="color:#2ecc71;font-weight:bold">${item.price}G</span> <span style="color:var(--text3);font-size:10px;text-decoration:line-through">${fairPrice}G</span>`
      : `<span style="color:#e67e22;font-weight:bold">${item.price}G</span>`;
    return `
      <div class="shop-item">
        <div class="si-info">
          <div class="si-name" style="color:${color}">${sc.icon} ${sc.name}
            <span class="tag" style="background:${color}22;color:${color}">${RARITY[sc.rarity].name}</span>
          </div>
          <div class="si-desc">${sc.desc} / 基礎${sc.base}</div>
          <div class="si-price">${priceLabel} ×${item.qty}</div>
        </div>
        <button class="btn btn-gold" onclick="buyMerchantItem(${i})" ${S.gold < item.price ? 'disabled' : ''}>購入</button>
      </div>
    `;
  }).join('');

  document.getElementById('chat-screen').innerHTML = `
    <div class="panel">
      <div class="panel-title">🧝 行商人ミラル</div>
      <div style="color:var(--text2);font-size:12px">次の入れ替えまで: ${getMerchantNextReset()}</div>
    </div>
    ${itemHtml}
  `;
}

function buyMerchantItem(idx) {
  const stock = getMerchantStock();
  const item = stock[idx];
  if (!item || S.gold < item.price) return;
  S.gold -= item.price;
  for (let i = 0; i < item.qty; i++) addScroll(item.key, 1);
  render();
}

function openGiftModal() {
  const keys = [...new Set(S.scrollItems.map(i=>i.key))];
  const scrollOpts = keys.map(k => `<option value="${k}">${SCROLLS[k].icon}${SCROLLS[k].name}(${countScrolls(k)}個)</option>`).join('');
  document.getElementById('gift-scroll-sel').innerHTML = scrollOpts || '<option value="">スクロールなし</option>';
  document.getElementById('gift-modal').classList.add('show');
}

function closeGiftModal() {
  document.getElementById('gift-modal').classList.remove('show');
}

function sendGift() {
  const type = document.getElementById('gift-scroll-sel').value;
  const qty = parseInt(document.getElementById('gift-qty').value) || 1;
  const price = parseInt(document.getElementById('gift-price').value) || 0;

  if (!type || countScrolls(type) < qty) {
    alert('スクロールが足りません');
    return;
  }

  removeScrollByKey(type, qty);
  if (price > 0) S.gold += price * qty;

  closeGiftModal();
  render();
}

// ==================== SCROLLS ====================

function renderScrolls() {
  const byAttr = { fire:[], ice:[], water:[], thunder:[] };
  S.scrollItems.forEach((item, idx) => {
    const sc = SCROLLS[item.key];
    if (sc) byAttr[sc.attr].push({ item, idx, sc });
  });

  // 同種・同Lvの枚数カウント
  const groups = {};
  S.scrollItems.forEach(item => {
    const gkey = `${item.key}_${item.lv}`;
    groups[gkey] = (groups[gkey] || 0) + 1;
  });

  const attrLabel = { fire:'🔥 火', ice:'❄️ 氷', water:'💧 水', thunder:'⚡ 雷' };

  let html = `
    <div class="panel">
      <div class="panel-title">📜 所持スクロール</div>
      <div style="color:var(--text2);font-size:11px">同種・同Lv 3枚で合成 → Lv+1</div>
    </div>
  `;

  for (const [attr, items] of Object.entries(byAttr)) {
    if (items.length === 0) continue;
    html += `<div class="section-title">${attrLabel[attr]}</div>`;
    // 同種・同Lvでまとめて表示
    const shown = new Set();
    items.forEach(({ item, sc }) => {
      const gkey = `${item.key}_${item.lv}`;
      if (shown.has(gkey)) return;
      shown.add(gkey);
      const cnt = groups[gkey];
      const color = RARITY[sc.rarity].color;
      const dmg = calcScrollDmg(item.key, item.lv);
      const canSynth = cnt >= 3 && item.lv < 10;
      const dmgAfter = canSynth ? calcScrollDmg(item.key, item.lv + 1) : null;
      const synthBorder = canSynth ? 'border-color:' + color + '66' : '';
      const dmgAfterHtml = canSynth ? ' → <span style="color:#2ecc71">' + dmgAfter + '</span>（合成後）' : '';
      const lvHtml = item.lv >= 10
        ? '<div style="color:var(--gold);font-size:11px">最大Lv</div>'
        : '<div style="color:var(--text3);font-size:11px">' + cnt + '/3枚</div>';
      const synthBtn = canSynth
        ? '<button class="btn btn-purple" onclick="synthesizeScroll(\'' + item.key + '\',' + item.lv + ')">合成</button>'
        : '';
      html += `
        <div class="shop-item" style="${synthBorder}">
          <div class="si-info">
            <div class="si-name" style="color:${color}">${sc.icon} ${sc.name}
              <span class="tag" style="background:${color}22;color:${color}">${RARITY[sc.rarity].name}</span>
              <span class="tag tag-gold">Lv${item.lv}</span>
              <span style="color:var(--text2);font-size:11px">×${cnt}</span>
            </div>
            <div class="si-desc">ダメージ: ${dmg}${dmgAfterHtml}</div>
            ${lvHtml}
          </div>
          ${synthBtn}
        </div>
      `;
    });
  }

  if (S.scrollItems.length === 0) html += '<div class="msg msg-info">所持スクロールなし</div>';

  // 空白の魔導書セクション
  if (!S.grimoires) S.grimoires = [];
  const eg = S.equipped.grimoire;
  html += '<div class="section-title">📖 空白の魔導書</div>';

  if (eg) {
    const g = GRIMOIRE[eg.rarity];
    const sc = SCROLLS[eg.scrollKey];
    const color = GRIMOIRE[eg.rarity].color;
    const dmg = Math.floor(calcScrollDmg(eg.scrollKey, eg.scrollLv || 1) * g.bulletMult);
    html += `
      <div class="panel" style="border-color:${color}44">
        <div style="color:${color};font-weight:bold">📖 ${g.name}（${RARITY[eg.rarity].name}）× ${sc ? sc.icon + sc.name : '?'} Lv${eg.scrollLv}</div>
        <div style="color:var(--text2);font-size:12px;margin-top:4px">魔弾ダメージ: ${dmg} / 倍率×${g.bulletMult}</div>
      </div>
    `;
  } else {
    html += '<div class="msg msg-info">魔導書未合成 — 魔弾はデフォルトダメージ</div>';
  }

  if (S.grimoires.length > 0) {
    html += '<div style="margin-top:8px">';
    S.grimoires.forEach((gItem, gIdx) => {
      const g = GRIMOIRE[gItem.rarity];
      const color = RARITY[gItem.rarity].color;
      const scrollOpts = S.scrollItems.map((sItem, sIdx) => {
        const sc = SCROLLS[sItem.key];
        return `<option value="${sIdx}">${sc.icon}${sc.name} Lv${sItem.lv}（${RARITY[sc.rarity].name}）</option>`;
      }).join('');
      html += `
        <div class="shop-item" style="border-color:${color}44;flex-direction:column;gap:6px">
          <div style="display:flex;align-items:center;gap:8px">
            <div style="color:${color};font-weight:bold">📖 ${g.name}（${RARITY[gItem.rarity].name}）× ${g.bulletMult}</div>
          </div>
          <div style="display:flex;gap:6px">
            <select id="grimoire-scroll-${gIdx}" style="flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:5px;color:var(--text);font-family:inherit;font-size:12px">
              ${scrollOpts || '<option>スクロールなし</option>'}
            </select>
            <button class="btn btn-purple" onclick="synthesizeGrimoire(${gIdx})" ${S.scrollItems.length === 0 ? 'disabled' : ''}>合成</button>
          </div>
        </div>
      `;
    });
    html += '</div>';
  }

  document.getElementById('scrolls-screen').innerHTML = html;
}

function synthesizeGrimoire(gIdx) {
  if (!S.grimoires || !S.grimoires[gIdx]) return;
  const sel = document.getElementById(`grimoire-scroll-${gIdx}`);
  if (!sel) return;
  const sIdx = parseInt(sel.value);
  const sItem = S.scrollItems[sIdx];
  if (!sItem) return;

  S.scrollItems.splice(sIdx, 1);
  const gItem = S.grimoires.splice(gIdx, 1)[0];

  // 既存の装備済み魔導書はインベントリに戻す
  if (!S.equipped) S.equipped = { head:null, body:null, ring:null, grimoire:null };
  if (S.equipped.grimoire) {
    S.inventory.push(S.equipped.grimoire);
  }

  const newGrimoire = { type:'grimoire', rarity: gItem.rarity, scrollKey: sItem.key, scrollLv: sItem.lv };
  S.equipped.grimoire = newGrimoire;

  saveGame();
  renderScrolls();
}

function synthesizeScroll(key, lv) {
  let removed = 0;
  S.scrollItems = S.scrollItems.filter(item => {
    if (item.key === key && item.lv === lv && removed < 3) { removed++; return false; }
    return true;
  });
  if (removed === 3) S.scrollItems.push({ key, lv: lv + 1 });
  saveGame();
  renderScrolls();
}

// ==================== 召喚 ====================

function renderSummon() {
  if (!S.contractBloods) S.contractBloods = {};
  if (!S.pets) S.pets = [];
  if (!S.activePets) S.activePets = [];
  const typeLabel = { attack:'攻撃型', magic:'魔法型', heal:'回復型', tank:'タンク型' };
  const typeColor = { attack:'#e74c3c', magic:'#9b59b6', heal:'#2ecc71', tank:'#3498db' };

  const bloods = Object.entries(S.contractBloods).filter(([,v]) => v > 0);

  let summonHtml = '';
  bloods.forEach(([mKey, cnt]) => {
    const m = MONSTERS[mKey];
    if (!m) return;
    const hasPet = S.pets.some(p => p.mKey === mKey);
    const color = typeColor[m.petType];
    summonHtml += `
      <div class="shop-item" style="border-color:${color}44">
        <div class="si-info">
          <div style="font-weight:bold">${m.icon} 契約の血：${m.name} <span style="color:var(--text2)">×${cnt}</span></div>
          <div style="color:${color};font-size:11px">${typeLabel[m.petType]}</div>
          <div style="color:var(--text2);font-size:11px">召契石1個（${SUMMON_STONE_PRICE}G）+ 血1枚</div>
        </div>
        <button class="btn btn-purple" onclick="summonPet('${mKey}')"
          ${hasPet || !S.summonStones || S.summonStones < 1 || cnt < 1 ? 'disabled' : ''}>
          ${hasPet ? '召喚済' : '召喚'}
        </button>
      </div>
    `;
  });

  let petsHtml = '';
  S.pets.forEach((pet, idx) => {
    const m = MONSTERS[pet.mKey];
    if (!m) return;
    const ps = petStats(pet.mKey, pet.lv);
    const color = typeColor[m.petType];
    const isActive = S.activePets.includes(idx);
    const cost = petLvUpCost(pet.lv);
    const bloodCount = S.contractBloods[pet.mKey] || 0;
    const canLvUp = pet.lv < 100 && bloodCount >= cost;
    const hp = pet.currentHp !== undefined ? pet.currentHp : ps.hp;
    petsHtml += `
      <div class="shop-item" style="border-color:${isActive ? color : 'var(--border)'}88;${isActive ? "background:" + color + "11" : ""}">
        <div class="si-info">
          <div style="font-weight:bold;color:${color}">${m.icon} ${m.name} <span style="color:var(--gold)">Lv${pet.lv}</span>${isActive ? ' <span class="tag tag-purple">出撃中</span>' : ''}</div>
          <div style="color:var(--text2);font-size:11px">${typeLabel[m.petType]} / HP:${hp}/${ps.hp} ATK:${ps.atk}</div>
          <div style="color:var(--text3);font-size:11px">LvUp: 血×${cost}枚 (所持${bloodCount})</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:4px">
          <button class="btn ${isActive ? 'btn-red' : 'btn-gold'}" style="font-size:11px;padding:3px 7px"
            onclick="toggleActivePet(${idx})"
            ${!isActive && S.activePets.length >= 3 ? 'disabled' : ''}>
            ${isActive ? '外す' : '出撃'}
          </button>
          <button class="btn btn-purple" style="font-size:11px;padding:3px 7px"
            onclick="levelUpPet(${idx})" ${!canLvUp ? 'disabled' : ''}>
            強化
          </button>
        </div>
      </div>
    `;
  });

  document.getElementById('summon-screen').innerHTML = `
    <div class="panel">
      <div class="panel-title">🐾 召喚（出撃: ${S.activePets.length}/3）</div>
      <div style="color:var(--text2);font-size:12px">所持GOLD: ${S.gold}G / 召契石: ${S.summonStones || 0}個</div>
    </div>
    ${bloods.length > 0 ? '<div class="section-title">🩸 召喚可能</div>' + summonHtml : ''}
    ${S.pets.length > 0 ? '<div class="section-title">🐾 所持ペット</div>' + petsHtml : ''}
    ${bloods.length === 0 && S.pets.length === 0 ? '<div class="msg msg-info">契約の血をドロップするとここに表示されます（ドロップ率1%）</div>' : ''}
  `;
}

function summonPet(mKey) {
  if (!S.contractBloods) S.contractBloods = {};
  if (!S.pets) S.pets = [];
  if (!S.summonStones || S.summonStones < 1) return;
  if (!S.contractBloods[mKey] || S.contractBloods[mKey] < 1) return;
  if (S.pets.some(p => p.mKey === mKey)) return;
  S.summonStones--;
  S.contractBloods[mKey]--;
  const ps = petStats(mKey, 1);
  S.pets.push({ mKey, lv: 1, currentHp: ps.hp });
  render();
}

function levelUpPet(idx) {
  if (!S.pets || !S.pets[idx]) return;
  const pet = S.pets[idx];
  const cost = petLvUpCost(pet.lv);
  if (!S.contractBloods) S.contractBloods = {};
  if ((S.contractBloods[pet.mKey] || 0) < cost) return;
  if (pet.lv >= 100) return;
  S.contractBloods[pet.mKey] -= cost;
  pet.lv++;
  const ps = petStats(pet.mKey, pet.lv);
  pet.currentHp = ps.hp;
  render();
}

function toggleActivePet(idx) {
  if (!S.activePets) S.activePets = [];
  const pos = S.activePets.indexOf(idx);
  if (pos >= 0) {
    S.activePets.splice(pos, 1);
  } else {
    if (S.activePets.length >= 3) return;
    S.activePets.push(idx);
    const pet = S.pets[idx];
    if (pet) {
      const ps = petStats(pet.mKey, pet.lv);
      pet.currentHp = ps.hp;
    }
  }
  render();
}

