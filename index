function unequip(slot) {
  const item = S.equipped && S.equipped[slot];
  if (item) S.inventory.push(item);
  if (!S.equipped) S.equipped = { head:null, body:null, ring:null };
  S.equipped[slot] = null;
  render();
}

function equipFromInventory(idx) {
  const item = S.inventory[idx];
  if (!item || !item.baseKey) return;
  const base = (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey]);
  if (!base) return;
  if (!S.equipped) S.equipped = { head:null, body:null, ring:null };
  if (S.equipped[base.slot]) S.inventory.push(S.equipped[base.slot]);
  S.equipped[base.slot] = item;
  S.inventory.splice(idx, 1);
  render();
}

function sellInventoryItem(idx) {
  const item = S.inventory[idx];
  if (!item) return;
  const base = item.baseKey ? (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey]) : null;
  const sellPrice = base ? Math.floor(base.price * 0.4) : 10;
  S.inventory.splice(idx, 1);
  S.gold += Math.max(1, sellPrice);
  render();
}

function openEquipModal(slot) {
  if (!S.equipped) S.equipped = { head:null, body:null, ring:null };
  const items = S.inventory.map((item, idx) => ({ item, idx }))
    .filter(({ item }) => item && item.baseKey && (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey]) && (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey]).slot === slot);
  document.getElementById('equip-modal-title').textContent = `${slot} 装備選択`;
  if (items.length === 0) {
    document.getElementById('equip-modal-list').innerHTML = '<div style="color:var(--text3)">インベントリに該当装備なし</div>';
  } else {
    document.getElementById('equip-modal-list').innerHTML = items.map(({ item, idx }) => {
      const base = (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey]);
      const color = RARITY[base.rarity].color;
      let stats = [];
      if (item.hp) stats.push(`HP+${item.hp}`);
      if (item.luk) stats.push(`LUK+${item.luk}`);
      if (item.mult && item.mult > 0) stats.push(`魔法×${item.mult}`);
      return `
        <div class="shop-item" style="margin-bottom:6px">
          <div class="si-info">
            <div style="font-weight:bold;color:${color}">${base.icon} ${base.name} <span class="tag" style="background:${color}22;color:${color}">${RARITY[base.rarity].name}</span></div>
            <div style="color:var(--text2);font-size:11px">${stats.join(' / ')}</div>
          </div>
          <button class="btn btn-gold" style="font-size:11px;padding:4px 8px" onclick="equipFromInventory(${idx});closeEquipModal()">装備</button>
        </div>
      `;
    }).join('');
  }
  document.getElementById('equip-modal').classList.add('show');
}

