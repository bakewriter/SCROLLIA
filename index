// ==================== STATS ====================

function effective() {
  let hp = S.baseHp + (S.lv - 1) * 8;
  let luk = S.baseLuk + Math.floor((S.lv - 1) / 2);
  let mult = 1.0;
  for (const slot of ['head','body','ring']) {
    const item = S.equipped && S.equipped[slot];
    if (!item) continue;
    hp   += item.hp  || 0;
    luk  += item.luk || 0;
    if (item.mult && item.mult > 0) mult *= item.mult;
  }
  return { hp, luk, mult };
}

function critRate() {
  return Math.min(0.5, effective().luk * 0.015);
}

function expNeeded() {
  return 40 + S.lv * 30;
}

// ==================== SCROLL DAMAGE ====================

function calcScrollDmg(scrollKey, scrollLv, isBoss) {
  const sc = SCROLLS[scrollKey];
  if (!sc) return 0;
  const rarMult = RARITY[sc.rarity].mult;
  const lvMult = 1 + (S.lv - 1) * 0.05;
  const slvMult = 1 + ((scrollLv || 1) - 1) * 0.15;
  const magicMult = effective().mult || 1.0;
  const bonus = getSeriesBonus();
  let seriesMult = 1.0;
  if (bonus.all_boost) seriesMult += bonus.all_boost;
  if (sc.attr === 'thunder' && bonus.thunder_boost) seriesMult += bonus.thunder_boost;
  if (sc.attr === 'ice'     && bonus.ice_boost)     seriesMult += bonus.ice_boost;
  if (isBoss && bonus.boss_boost) seriesMult += bonus.boss_boost;
  return Math.floor(sc.base * rarMult * lvMult * slvMult * magicMult * seriesMult);
}

// scrollItems ヘルパー
function countScrolls(key) {
  return S.scrollItems.filter(i => i.key === key).length;
}
function addScroll(key, lv) {
  S.scrollItems.push({ key, lv: lv || 1 });
}
function removeScrollByKey(key, qty) {
  let removed = 0;
  S.scrollItems = S.scrollItems.filter(i => {
    if (i.key === key && removed < qty) { removed++; return false; }
    return true;
  });
}

