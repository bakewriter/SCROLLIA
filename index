}

async function fbLoad() {
  if (!window._fbUser || !window._fb) return false;
  try {
    const { db, doc, getDoc } = window._fb;
    const snap = await getDoc(doc(db, 'saves', window._fbUser.uid));
    if (snap.exists()) {
      const data = snap.data();
      delete data.updatedAt;
      S = Object.assign(DEFAULT_STATE(), data);
      if (!S.scrollItems) S.scrollItems = [];
      if (!S.equipped) S.equipped = { head:null, body:null, ring:null, grimoire:null };
      if (!S.bossBadges) S.bossBadges = {};
      if (!S.stageBadges) S.stageBadges = {};
      if (!S.encounteredMonsters) S.encounteredMonsters = {};
      if (!S.inventory) S.inventory = [];
      if (!S.grimoires) S.grimoires = [];
      if (!S.pets) S.pets = [];
      if (!S.activePets) S.activePets = [];
      if (!S.contractBloods) S.contractBloods = {};
      if (!S.bazaarListings) S.bazaarListings = [];
      dbg('Firestore load OK');
      return true;
    }
  } catch(e) { dbg('LOAD ERROR: ' + e.message); }
  return false;
}

