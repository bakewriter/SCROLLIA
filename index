        <div style="font-weight:bold;font-size:16px">${escHtml(p.displayName)}</div>
        <div style="color:var(--text2);font-size:12px">最高到達: ${p.maxArea || '未到達'} ${p.maxStage && p.maxStage < 99 ? 'S' + p.maxStage : ''}</div>
