// ペットステータス計算
function petStats(mKey, lv) {
  const m = MONSTERS[mKey];
  if (!m) return { hp: 0, atk: 0 };
  const lvMult = 1 + (lv - 1) * 0.1;
  const rarMult = m.superRare ? 2.5 : m.rare ? 1.5 : 1.0;
  return {
    hp:  Math.floor(m.baseHp  * lvMult * rarMult),
    atk: Math.floor(m.baseAtk * lvMult * rarMult),
  };
}

// レベルアップ必要血の数
function petLvUpCost(lv) {
  return Math.floor(lv * 1.5);
}

// ペット行動（戦闘中1ターン）
function petAct(pet, enemy) {
  const m = MONSTERS[pet.mKey];
  const stats = petStats(pet.mKey, pet.lv);
  const ef = effective();
  let msg = '';

  if (pet.currentHp <= 0) return ''; // 戦闘不能

  switch (m.petType) {
    case 'attack': {
      const dmg = Math.max(1, Math.floor(stats.atk * (0.8 + Math.random() * 0.4)));
      enemy.hp -= dmg;
      msg = `🐾 ${m.name}の攻撃！ ${dmg}ダメージ`;
      break;
    }
    case 'magic': {
      const dmg = Math.max(1, Math.floor(stats.atk * (1.0 + Math.random() * 0.5)));
      enemy.hp -= dmg;
      msg = `✨ ${m.name}の魔法攻撃！ ${dmg}ダメージ`;
      break;
    }
    case 'heal': {
      const roll = Math.random();
      if (roll < 0.33) {
        const heal = Math.max(1, Math.floor(stats.atk * 0.8));
        S.currentHp = Math.min(ef.hp, S.currentHp + heal);
        msg = `💚 ${m.name}の回復！ HP+${heal}`;
      } else if (roll < 0.66) {
        pet.shield = true;
        msg = `🛡️ ${m.name}の防御！ 次の攻撃を軽減`;
      } else {
        const dmg = Math.max(1, Math.floor(stats.atk * 0.5));
        enemy.hp -= dmg;
        msg = `⚔️ ${m.name}の攻撃！ ${dmg}ダメージ`;
      }
      break;
    }
    case 'tank': {
      if (Math.random() < 0.5) {
        pet.taunt = true;
        msg = `🛡️ ${m.name}が身代わりを構えた！`;
      } else {
        const dmg = Math.max(1, Math.floor(stats.atk * 0.6));
        enemy.hp -= dmg;
        msg = `👊 ${m.name}の攻撃！ ${dmg}ダメージ`;
      }
      break;
    }
  }
  return msg;
}
