        label = `📖 空白の魔導書（${RARITY[item.grimoireRarity]?.name}）`;
      } else if (item.scrollType && SCROLLS[item.scrollType]) {
        const sc = SCROLLS[item.scrollType];
        color = RARITY[sc.rarity]?.color || color;
        label = `${sc.icon} ${sc.name} ×${item.qty}`;
      }
      return `
        <div class="shop-item" style="border-color:${color}44">
          <div class="si-info">
            <div style="font-weight:bold;color:${color}">${label}</div>
            <div style="color:var(--text2);font-size:11px">${item.price}G</div>
          </div>
          <button class="btn btn-gold" style="font-size:11px;padding:3px 7px"
            onclick="buyFromUserProfile('${uid}',${idx})" ${!window._fbUser || S.gold < item.price ? 'disabled' : ''}>購入</button>
        </div>`;
    }).join('');
  } else {
    bazaarHtml = '<div class="msg msg-info">出品なし</div>';
  }

  const dmBtn = isMe ? '' : `<button class="btn btn-purple" style="width:100%;margin-top:8px" onclick="openDM('${uid}','${escHtml(p.displayName)}')">💬 DMを送る</button>`;

