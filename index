  const r = Math.random();
  if (r < 0.005) return area.superRare;
  if (r < 0.055) return area.rare;
  return area.normal[Math.floor(Math.random() * area.normal.length)];
}

function _startBattle(areaKey, stage, mKey, isBoss, battleNum) {
  S.encounteredMonsters[mKey] = true;
  const m = MONSTERS[mKey];
  const lvBonus = Math.max(0, S.lv - 3);
  const enemyHp = m.hp + lvBonus * 3;
  const enemyAtk = m.atk + Math.floor(lvBonus * 0.5);
  const label = isBoss
    ? `💥 BOSS ${m.icon}${m.name}が立ちはだかる！`
    : `⚔️ [${battleNum}/5] ${m.icon}${m.name}が現れた！${m.rare ? '（レア！）' : m.superRare ? '（超レア！！）' : ''}`;
  COMBAT = {
    mKey, areaKey, stage, isBoss,
    battleNum: battleNum || 1,
    enemyHp, enemyMaxHp: enemyHp, enemyAtk,
    log: [label],
    totalExp: 0, totalGold: 0, droppedScrolls: [], droppedEquips: [], lvUps: [],
  };
  currentTab = 'combat';
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('combat-screen').classList.add('active');
  render();
}

function startExplore(areaKey, stage) {
  const area = AREAS[areaKey];
  if (stage >= 5) {
    _startBattle(areaKey, stage, area.boss, true, null);
  } else {
    _startBattle(areaKey, stage, _pickMonster(area), false, 1);
  }
}

// ==================== COMBAT ====================

function renderCombat() {
  if (!COMBAT) { renderExplore(); return; }
  const m = MONSTERS[COMBAT.mKey];
  const ef = effective();
  const hpPct = Math.max(0, Math.round(S.currentHp / ef.hp * 100));
  const ehpPct = Math.max(0, Math.round(COMBAT.enemyHp / COMBAT.enemyMaxHp * 100));

  // ペット表示
  if (!S.activePets) S.activePets = [];
  if (!S.pets) S.pets = [];
  const typeIcon = { attack:'⚔️', magic:'✨', heal:'💚', tank:'🛡️' };
  let activePetHtml = '';
  if (S.activePets.length > 0) {
    activePetHtml = `<div style="display:flex;gap:6px;margin-bottom:6px;flex-wrap:wrap">`;
    S.activePets.forEach(pi => {
      const pet = S.pets[pi];
      if (!pet) return;
      const pm = MONSTERS[pet.mKey];
      const ps = petStats(pet.mKey, pet.lv);
      const hpPct = Math.max(0, Math.round((pet.currentHp || ps.hp) / ps.hp * 100));
      activePetHtml += `
        <div style="flex:1;min-width:80px;background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:5px;font-size:11px;text-align:center">
          <div>${pm.icon} ${pm.name}</div>
          <div style="color:var(--text2)">${typeIcon[pm.petType]} Lv${pet.lv}</div>
          <div style="background:#1a0a0a;border-radius:2px;height:4px;margin:3px 0">
            <div style="width:${hpPct}%;height:100%;background:#2ecc71;border-radius:2px"></div>
          </div>
          <div style="color:var(--text2)">${pet.currentHp || ps.hp}/${ps.hp}</div>
        </div>
      `;
    });
    activePetHtml += `</div>`;
  }

  if (!COMBAT.scrollSortDesc) COMBAT.scrollSortDesc = true;
  const rarityOrder = { architect:4, legend:3, epic:2, rare:1, common:0 };

  // グループ化: attr → rarity → items
  const grouped = {};
  S.scrollItems.forEach((item, idx) => {
    const sc = SCROLLS[item.key];
    if (!sc) return;
    const rk = sc.rarity;
    if (!grouped[rk]) grouped[rk] = {};
    const ak = sc.attr;
    if (!grouped[rk][ak]) grouped[rk][ak] = [];
    grouped[rk][ak].push({ item, idx });
  });

  const rarityKeys = Object.keys(grouped).sort((a,b) =>
    COMBAT.scrollSortDesc ? rarityOrder[b] - rarityOrder[a] : rarityOrder[a] - rarityOrder[b]
  );
  const rarityLabel = { common:'コモン', rare:'レア', epic:'エピック', legend:'レジェンド', architect:'アーキテクト' };
  const attrOrder = ['fire','ice','water','thunder'];

  let scrollHtml = '';
  rarityKeys.forEach(rk => {
    const color = RARITY[rk].color;
    scrollHtml += `<div style="grid-column:1/-1;font-size:11px;font-weight:bold;color:${color};margin-top:6px;padding-bottom:2px;border-bottom:1px solid ${color}33">${rarityLabel[rk]}</div>`;
    attrOrder.forEach(ak => {
      if (!grouped[rk][ak]) return;
      grouped[rk][ak].forEach(({ item, idx }) => {
        const sc = SCROLLS[item.key];
        scrollHtml += `
          <button class="scroll-btn" onclick="useScroll(${idx})" style="border-color:${color}55">
            <span class="s-icon">${sc.icon}</span>
            <span class="s-name" style="color:${color};font-size:10px">${sc.name}</span>
            <span class="s-count" style="color:${color}">Lv${item.lv}</span>
          </button>
        `;
      });
    });
  });
  if (!scrollHtml) scrollHtml = '<div style="color:var(--text3);font-size:12px;grid-column:1/-1;text-align:center">スクロールなし</div>';

  let logHtml = COMBAT.log.slice(-12).map(entry => {
    const l = typeof entry === 'string' ? entry : entry.msg;
    const type = typeof entry === 'string' ? 'sys' : (entry.type || 'sys');
    return `<div class="log-line log-${type}">${l}</div>`;
  }).join('');

  document.getElementById('combat-screen').innerHTML = `
    <div class="combat-top">
      <div class="combatant">
        <div class="c-name player">あなた</div>
        <div style="text-align:center;margin:4px 0"><img src="${PLAYER_IMAGE}" style="height:100px;object-fit:contain;image-rendering:pixelated"></div>
        <div class="hp-bar-wrap"><div class="hp-bar player" style="width:${hpPct}%"></div></div>
        <div class="c-hp">${S.currentHp} / ${ef.hp}</div>
        ${S.activePets && S.activePets.length > 0 ? '<div style="display:flex;gap:4px;margin-top:6px;justify-content:center;flex-wrap:wrap">' + S.activePets.map(pi => {
          const pet = S.pets[pi];
          if (!pet) return '';
          const pm = MONSTERS[pet.mKey];
          const ps = petStats(pet.mKey, pet.lv);
          const petImg = MONSTER_IMAGES[pet.mKey];
          const petHp = pet.currentHp !== undefined ? pet.currentHp : ps.hp;
          const petHpPct = Math.max(0, Math.round(petHp / ps.hp * 100));
          const typeIcon = {attack:'⚔️',magic:'✨',heal:'💚',tank:'🛡️'}[pm.petType] || '';
          return '<div style="width:72px;background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:4px;text-align:center">'
            + (petImg ? '<img src="' + petImg + '" style="height:40px;object-fit:contain;image-rendering:pixelated">' : pm.icon)
            + '<div style="font-size:9px;color:var(--text2);margin-top:2px">' + typeIcon + ' Lv' + pet.lv + '</div>'
            + '<div style="background:#1a0a0a;border-radius:2px;height:3px;margin-top:2px"><div style="width:' + petHpPct + '%;height:100%;background:#2ecc71;border-radius:2px"></div></div>'
            + '<div style="font-size:8px;color:var(--text3)">' + petHp + '/' + ps.hp + '</div>'
            + '</div>';
        }).join('') + '</div>' : ''}
      </div>
      <div class="combatant">
        <div class="c-name enemy">${m.icon} ${m.name}</div>
        ${MONSTER_IMAGES[COMBAT.mKey] ? '<div style="text-align:center;margin:4px 0"><img src="' + MONSTER_IMAGES[COMBAT.mKey] + '" style="height:100px;object-fit:contain;image-rendering:pixelated"></div>' : ''}
        <div class="hp-bar-wrap"><div class="hp-bar enemy" style="width:${ehpPct}%"></div></div>
        <div class="c-hp">${COMBAT.enemyHp} / ${COMBAT.enemyMaxHp}</div>
        ${m.weak && m.weak.length > 0 ? '<div style="font-size:10px;color:#f39c12;margin-top:2px">弱点: ' + m.weak.map(w => ({fire:'🔥火',ice:'❄️氷',water:'💧水',thunder:'⚡雷'}[w]||w)).join(' ') + '</div>' : ''}
      </div>
    </div>
    <div class="combat-log">${logHtml}</div>
    <div style="display:flex;gap:6px;margin-bottom:6px">
      ${(() => {
        const eg = S.equipped.grimoire;
        if (eg && eg.scrollKey) {
          const sc = SCROLLS[eg.scrollKey];
          const color = GRIMOIRE[eg.rarity].color;
          const attr = {fire:'🔥火',ice:'❄️氷',water:'💧水',thunder:'⚡雷'}[sc.attr] || sc.attr;
          return `<button class="btn btn-blue" style="flex:1;font-size:12px" onclick="useMagicBullet()">✨ 魔弾 <span style="color:${color}">${attr} Lv${eg.scrollLv}</span></button>`;
        }
        return `<button class="btn btn-blue" style="flex:1;font-size:12px" onclick="useMagicBullet()">✨ 魔弾 <span style="color:var(--text2)">無属性 Lv${S.lv}</span></button>`;
      })()}
      <button class="btn" style="border-color:var(--border);color:var(--text2);font-size:11px;padding:4px 8px" onclick="toggleScrollSort()">
        ${COMBAT.scrollSortDesc ? '↓高→低' : '↑低→高'}
      </button>
    </div>
    <div class="scroll-grid">${scrollHtml}</div>
    <div class="combat-actions">
      <button class="btn btn-red" onclick="fleeCombat(false)">逃走(-10%G)</button>
    </div>
  `;
  // auto-scroll log
  const logEl = document.querySelector('.combat-log');
  if (logEl) logEl.scrollTop = logEl.scrollHeight;
}

function toggleScrollSort() {
  if (COMBAT) COMBAT.scrollSortDesc = !COMBAT.scrollSortDesc;
  render();
}

function addLog(msg, type) {
  COMBAT.log.push({ msg, type: type || 'sys' });
}

function useMagicBullet() {
  if (!COMBAT) return;
  const m = MONSTERS[COMBAT.mKey];
  const eg = S.equipped.grimoire;

  let dmg, extra = '';

  if (eg && eg.scrollKey) {
    // 合成済み魔導書
    const baseDmg = calcScrollDmg(eg.scrollKey, eg.scrollLv || 1);
    const mult = GRIMOIRE[eg.rarity].bulletMult;
    dmg = Math.max(1, Math.floor(baseDmg * mult));
    const sc = SCROLLS[eg.scrollKey];
    if (m.weak && m.weak.includes(sc.attr)) {
      dmg = Math.floor(dmg * 1.5);
      extra += '⚡弱点×1.5 ';
    }
    const color = GRIMOIRE[eg.rarity].color;
    extra += `<span style="color:${color}">[${RARITY[eg.rarity].name}魔導書]</span>`;
  } else {
    // デフォルト魔弾
    const lvMult = 1 + (S.lv - 1) * 0.05;
    dmg = Math.max(1, Math.floor(8 * lvMult));
  }

  if (Math.random() < critRate()) {
    dmg = Math.floor(dmg * 1.7);
    extra += '💥クリティカル！';
  }

  COMBAT.enemyHp -= dmg;
  addLog(`✨ 魔弾 → ${m.name}に ${dmg}ダメージ ${extra}`, 'player');

  if (COMBAT.enemyHp <= 0) { combatVictory(); return; }

  // enemy turn
  doPetActions();
  if (COMBAT.enemyHp <= 0) { combatVictory(); return; }
  doEnemyAttack();
  if (S.currentHp <= 0) { combatDefeat(); return; }

  render();
}

function doPetActions() {
  if (!S.activePets || !S.pets) return;
  const enemy = COMBAT;
  S.activePets.forEach(pi => {
    const pet = S.pets[pi];
    if (!pet || (pet.currentHp !== undefined && pet.currentHp <= 0)) return;
    const msg = petAct(pet, enemy);
    if (msg) addLog(msg, 'ally');
  });
}

function doEnemyAttack() {
  const m = MONSTERS[COMBAT.mKey];
  // タンクペットが身代わり
  let tanked = false;
  if (S.activePets && S.pets) {
    S.activePets.forEach(pi => {
      const pet = S.pets[pi];
      if (!pet || tanked) return;
      if (pet.taunt && pet.currentHp > 0) {
        const ps = petStats(pet.mKey, pet.lv);
        const dmg = Math.floor(COMBAT.enemyAtk * 0.8);
        pet.currentHp = Math.max(0, (pet.currentHp || ps.hp) - dmg);
        addLog(`🛡️ ${MONSTERS[pet.mKey].name}が身代わり！ ${dmg}ダメージ`, 'ally');
        pet.taunt = false;
        tanked = true;
      }
    });
  }
  if (!tanked) {
    S.currentHp -= COMBAT.enemyAtk;
    addLog(`⚠️ ${m.name}の攻撃！ ${COMBAT.enemyAtk}ダメージを受けた`, 'enemy');
  }
}

function useScroll(idx) {
  if (!COMBAT) return;
  const item = S.scrollItems[idx];
  if (!item) return;
  const sc = SCROLLS[item.key];
  const m = MONSTERS[COMBAT.mKey];

  // 消費
  S.scrollItems.splice(idx, 1);

  let dmg = calcScrollDmg(item.key, item.lv);
  let extra = '';

  if (m.weak && m.weak.includes(sc.attr)) {
    dmg = Math.floor(dmg * 1.5);
    extra += '⚡弱点×1.5 ';
  }
  if (Math.random() < critRate()) {
    dmg = Math.floor(dmg * 1.7);
    extra += '💥クリティカル！';
  }

  COMBAT.enemyHp -= dmg;
  const rarColor = RARITY[sc.rarity].color;
  addLog(`${sc.icon} <span style="color:${rarColor}">${sc.name} Lv${item.lv}</span> → ${m.name}に ${dmg}ダメージ ${extra}`, 'player');

  if (COMBAT.enemyHp <= 0) { combatVictory(); return; }

  doPetActions();
  if (COMBAT.enemyHp <= 0) { combatVictory(); return; }
  doEnemyAttack();
  if (S.currentHp <= 0) { combatDefeat(); return; }

  render();
}

function combatVictory() {

  const m = MONSTERS[COMBAT.mKey];
  const bonus = getSeriesBonus();
  const expGain = Math.floor((m.hp / 5 + COMBAT.enemyAtk) * (1 + (bonus.exp_boost || 0)));
  const goldGain = m.gold + Math.floor(Math.random() * Math.ceil(m.gold * 0.3));

  S.exp += expGain;
  S.gold += goldGain;
  S.encounteredMonsters[COMBAT.mKey] = true;

  // accumulate totals
  COMBAT.totalExp = (COMBAT.totalExp || 0) + expGain;
  COMBAT.totalGold = (COMBAT.totalGold || 0) + goldGain;

  // 魔照時間（19-21時）はドロップ率2倍
  const hour = new Date().getHours();
  const magicHour = hour >= 19 && hour < 21;
  const dropMult = magicHour ? 2 : 1;

  // drop scroll
  let dropMsg = '';
  const dropChance = 0.15 * dropMult;
  if (Math.random() < dropChance) {
    const mRarity = MONSTERS[COMBAT.mKey].superRare ? 'rare' : MONSTERS[COMBAT.mKey].rare ? 'rare' : MONSTERS[COMBAT.mKey].boss ? 'epic' : 'common';
    const pool = SCROLL_DROP_BY_RARITY[mRarity];
    const dropKey = pool[Math.floor(Math.random() * pool.length)];
    const area = AREAS[COMBAT.areaKey];
    const [minLv, maxLv] = area ? area.dropLv : [1, 2];
    const dropLv = minLv + Math.floor(Math.random() * (maxLv - minLv + 1));
    S.scrollItems.push({ key: dropKey, lv: dropLv });
    COMBAT.droppedScrolls = COMBAT.droppedScrolls || [];
    COMBAT.droppedScrolls.push({ key: dropKey, lv: dropLv });
    const sc = SCROLLS[dropKey];
    const scColor = RARITY[sc.rarity].color;
    dropMsg = `📜 <span style="color:${scColor}">${sc.icon}${sc.name} Lv${dropLv}（${RARITY[sc.rarity].name}）</span>を入手！`;
  }

  // 固有装備ドロップ（レア50%、超レア70%）
  const uniquePool = UNIQUE_DROPS[COMBAT.mKey];
  if (uniquePool) {
    const uniqueChance = m.superRare ? 0.70 : m.rare ? 0.50 : 0;
    if (Math.random() < uniqueChance * dropMult) {
      const picked = uniquePool[Math.floor(Math.random() * uniquePool.length)];
      const rolled = rollSeriesEquipStats(picked);
      if (rolled) {
        S.inventory.push(rolled);
        COMBAT.droppedEquips = COMBAT.droppedEquips || [];
        COMBAT.droppedEquips.push(rolled);
        const base = SERIES_EQUIP[picked];
        dropMsg += ` ✨ <span style="color:${RARITY['legend'].color}">${base.icon}${base.name}（シリーズ装備！）</span>`;
      }
    }
  }

  // drop equipment
  const equipDropChance = 0.05 * dropMult;
  if (Math.random() < equipDropChance && m.equipDrops && m.equipDrops.length > 0) {
    const oldKey = m.equipDrops[Math.floor(Math.random() * m.equipDrops.length)];
    // 旧キーを新キーにマップ
    const newKey = EQUIP_LEGACY_MAP[oldKey] || oldKey;
    const rolled = rollEquipStats(newKey);
    if (rolled) {
      S.inventory.push(rolled);
      COMBAT.droppedEquips = COMBAT.droppedEquips || [];
      COMBAT.droppedEquips.push(rolled);
      const base = EQUIPMENT_BASE[newKey];
      const eqColor = RARITY[base.rarity].color;
      dropMsg += ` ⚔️ <span style="color:${eqColor}">${base.icon}${base.name}（${RARITY[base.rarity].name}）</span>を入手！`;
    }
  }

  // drop contract blood (1%、竜の聖域クリア後のみ)
  if (S.bossBadges && S.bossBadges['dragon_lair'] && Math.random() < 0.01 * dropMult) {
    if (!S.contractBloods) S.contractBloods = {};
    S.contractBloods[COMBAT.mKey] = (S.contractBloods[COMBAT.mKey] || 0) + 1;
    COMBAT.droppedEquips = COMBAT.droppedEquips || [];
    COMBAT.droppedEquips.push({ isBlood: true, mKey: COMBAT.mKey });
    dropMsg += ` 🩸 契約の血：${m.name}を入手！`;
  }

  // drop grimoire
  const r = Math.random();
  let cumulative = 0;
  for (const entry of GRIMOIRE_DROP) {
    cumulative += entry.chance * dropMult;
    if (r < cumulative) {
      if (!S.grimoires) S.grimoires = [];
      S.grimoires.push({ rarity: entry.rarity });
      COMBAT.droppedEquips = COMBAT.droppedEquips || [];
      COMBAT.droppedEquips.push({ isGrimoire: true, rarity: entry.rarity });
      const g = GRIMOIRE[entry.rarity];
      dropMsg += ` 📖 <span style="color:${RARITY[entry.rarity].color}">${g.name}（${RARITY[entry.rarity].name}）</span>を入手！`;
      break;
    }
  }

  // level up
  let lvMsg = '';
  while (S.exp >= expNeeded()) {
    S.exp -= expNeeded();
    S.lv++;
    S.currentHp = effective().hp;
    COMBAT.lvUps = COMBAT.lvUps || [];
    COMBAT.lvUps.push(S.lv);
    lvMsg += ` 🆙 Lv${S.lv}にアップ！`;
  }

  // boss badge
  const areaKey = COMBAT.areaKey;
  let stageMsg = '';
  if (areaKey && COMBAT.isBoss && !S.bossBadges[areaKey]) {
    S.bossBadges[areaKey] = true;
    stageMsg = `👑 BOSSを討伐！クリアバッジ獲得！`;
  } else if (areaKey && COMBAT.isBoss) {
    stageMsg = `👑 BOSS再討伐！`;
  }

  addLog(`✨ ${m.name}を倒した！ EXP+${expGain} GOLD+${goldGain}`, 'sys');
  if (dropMsg) addLog(dropMsg, 'drop');
  if (lvMsg) addLog(lvMsg);
  if (stageMsg) addLog(stageMsg);

  const wasBoss = COMBAT.isBoss;
  const clearedArea = areaKey;
  const clearedStage = COMBAT.stage;
  const nextBattle = (COMBAT.battleNum || 1) + 1;
  const totalExp = COMBAT.totalExp || 0;
  const totalGold = COMBAT.totalGold || 0;
  const droppedScrolls = COMBAT.droppedScrolls || [];
  const droppedEquips = COMBAT.droppedEquips || [];
  const lvUps = COMBAT.lvUps || [];

  // 通常ステージ: 5連戦継続
  if (!wasBoss && nextBattle <= 5) {
    const area = AREAS[clearedArea];
    const nextMKey = _pickMonster(area);
    const prevLog = COMBAT.log;
    const acc = { totalExp: COMBAT.totalExp, totalGold: COMBAT.totalGold, droppedScrolls: COMBAT.droppedScrolls, droppedEquips: COMBAT.droppedEquips, lvUps: COMBAT.lvUps };
    COMBAT = null;
    saveGame();
    setTimeout(() => {
      _startBattle(clearedArea, clearedStage, nextMKey, false, nextBattle);
      COMBAT.log = [...prevLog, `--- 次の敵 ---`, COMBAT.log[0]];
      Object.assign(COMBAT, acc);
      render();
    }, 600);
    return;
  }

  // 5戦終了 or BOSS
  if (!wasBoss) {
    const sNum = (clearedStage || 0) + 1;
    const bKey = `${clearedArea}_s${sNum}`;
    if (!S.stageBadges[bKey]) S.stageBadges[bKey] = true;
  }

  COMBAT = null;
  saveGame();

  const subText = wasBoss
    ? (AREAS[clearedArea] ? AREAS[clearedArea].name + ' BOSS討伐' : '')
    : `ステージ ${(clearedStage || 0) + 1} クリア`;

  // リザルトリスト
  const resultLines = [];
  resultLines.push(`⭐ EXP +${totalExp}　💰 GOLD +${totalGold}`);
  if (lvUps && lvUps.length > 0) resultLines.push(`🆙 Lv${lvUps.join(', Lv')} にアップ！`);
  if (droppedScrolls && droppedScrolls.length > 0) {
    droppedScrolls.forEach(item => {
      if (SCROLLS[item.key]) resultLines.push(`${SCROLLS[item.key].icon} ${SCROLLS[item.key].name} Lv${item.lv}`);
    });
  }
  if (droppedEquips && droppedEquips.length > 0) {
    droppedEquips.forEach(item => {
      if (item.isGrimoire) {
        resultLines.push(`📖 空白の魔導書（${RARITY[item.rarity].name}）`);
      } else if (item.isBlood) {
        const bm = MONSTERS[item.mKey];
        if (bm) resultLines.push(`🩸 契約の血：${bm.name}`);
      } else if (item.baseKey) {
        const base = (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey]);
        if (base) resultLines.push(`${base.icon} ${base.name}（${RARITY[base.rarity].name}）`);
      }
    });
  }

  // ステージリストに戻る前にexplore画面を表示しておく
  renderStageList(clearedArea);

  showResult('clear', subText, resultLines, () => {
    S.currentHp = effective().hp;
    renderStageList(clearedArea);
  });
}

function goTown() {
  S.currentHp = effective().hp;
  if (COMBAT && COMBAT.areaKey) {
    const areaKey = COMBAT.areaKey;
    COMBAT = null;
    renderStageList(areaKey);
  } else {
    COMBAT = null;
    switchTab('town');
  }
}

function showResult(type, sub, lines, cb) {
  const el = document.getElementById('result-overlay');
  if (!el) { dbg('ERROR: result-overlay not found'); if (cb) cb(); return; }
  el.className = `show ${type}`;
  document.getElementById('result-text').textContent = type === 'lose' ? 'LOSE' : 'CLEAR';
  document.getElementById('result-sub').textContent = sub || '';
  document.getElementById('result-badge').textContent = type === 'clear' ? (sub && sub.includes('BOSS') ? '👑' : '✅') : '';
  const listEl = document.getElementById('result-list');
  if (listEl) listEl.innerHTML = (lines || []).map(l => `<div>${l}</div>`).join('');
  const dismiss = () => {
    el.classList.remove('show');
    el.removeEventListener('click', dismiss);
    if (cb) cb();
  };
  el.addEventListener('click', dismiss);
}

function combatDefeat() {
  const penalty = Math.floor(S.gold * 0.15);
  S.gold = Math.max(0, S.gold - penalty);
  addLog(`💀 敗北... GOLD-${penalty}`, 'enemy');
  const areaKey = COMBAT ? COMBAT.areaKey : null;
  COMBAT = null;
  render();
  showResult('lose', `GOLD -${penalty}`, [], () => {
    S.currentHp = effective().hp;
    if (areaKey) renderStageList(areaKey);
    else switchTab('town');
  });
}

function fleeCombat(silent) {
  if (!silent) {
    const penalty = Math.floor(S.gold * 0.1);
    S.gold = Math.max(0, S.gold - penalty);
  }
  const areaKey = COMBAT ? COMBAT.areaKey : null;
  COMBAT = null;
  saveGame();
  if (!silent) {
    if (areaKey) renderStageList(areaKey);
    else goTown();
  }
}

