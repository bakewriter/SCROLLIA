    const base = (item.baseKey && (EQUIPMENT_BASE[item.baseKey] || SERIES_EQUIP[item.baseKey])) || null;
    if (item.type === 'grimoire') {
      const sc = SCROLLS[item.scrollKey];
      const color = RARITY[item.rarity]?.color || 'var(--text)';
      return `<div style="color:${color};font-size:12px">📖 空白の魔導書（${RARITY[item.rarity]?.name}）${sc ? sc.icon + sc.name + ' Lv' + item.scrollLv : ''}</div>`;
    }
    if (!base) return `<div style="color:var(--text3);font-size:12px">${slotLabel[slot]}: 不明</div>`;
    const color = RARITY[base.rarity]?.color || 'var(--text)';
    let stats = [];
    if (item.hp) stats.push(`HP+${item.hp}`);
    if (item.luk) stats.push(`LUK+${item.luk}`);
    if (item.mult) stats.push(`魔法×${item.mult}`);
    return `<div style="color:${color};font-size:12px">${base.icon} ${base.name} <span style="color:var(--text3)">${stats.join('/')}</span></div>`;
  }).join('');

  const listings = (p.bazaarListings || []).filter(l => !l.seller || l.seller !== 'あなた');
  let bazaarHtml = '';
  if (listings.length > 0) {
    bazaarHtml = listings.map((item, idx) => {
      let label = '', color = 'var(--text)';
